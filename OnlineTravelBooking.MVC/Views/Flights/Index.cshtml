@model OnlineTravelBooking.MVC.Models.FlightsIndexViewModel

@{
    ViewData["Title"] = "Flights";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Flights</h2>
    <a class="btn btn-primary" asp-action="Create">Create New</a>
</div>

<!-- Search card -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" asp-action="Search" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label small">Destination City</label>
                <input name="DestinationCity" value="@ViewContext.HttpContext.Request.Query["DestinationCity"]" class="form-control" placeholder="e.g. London" />
            </div>
            <div class="col-sm-3">
                <label class="form-label small">Departure From</label>
                <input name="DepartureFromUtc" value="@ViewContext.HttpContext.Request.Query["DepartureFromUtc"]" type="datetime-local" class="form-control" />
            </div>
            <div class="col-sm-3">
                <label class="form-label small">Departure To</label>
                <input name="DepartureToUtc" value="@ViewContext.HttpContext.Request.Query["DepartureToUtc"]" type="datetime-local" class="form-control" />
            </div>
            <div class="col-sm-1">
                <label class="form-label small">Pax</label>
                <input name="NumberOfPassengers" value="@ViewContext.HttpContext.Request.Query["NumberOfPassengers"]" type="number" min="1" class="form-control" />
            </div>
            <div class="col-sm-1 text-end">
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
    </div>
</div>

@if(TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if(TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-primary text-white">
                <tr>
                    <th>Flight #</th>
                    <th>Airline</th>
                    <th>Route</th>
                    <th>Departure</th>
                    <th>Arrival</th>
                    <th>Prices</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var f in Model.Flights)
                {
                    <tr>
                        <td class="align-middle fw-semibold">@f.FlightNumber</td>
                        <td class="align-middle">@f.AirlineName</td>
                        <td class="align-middle">@f.OriginCity (@f.OriginAirportCode) --> @f.DestinationCity (@f.DestinationAirportCode)</td>
                        <td class="align-middle">@f.DepartureTimeUtc.ToLocalTime().ToString("g")</td>
                        <td class="align-middle">@f.ArrivalTimeUtc.ToLocalTime().ToString("g")</td>
                        <td class="align-middle">E: <span class="text-success">@f.EconomyPrice.ToString("C")</span><br/>B: <span class="text-info">@f.BusinessPrice.ToString("C")</span><br/>F: <span class="text-warning">@f.FirstClassPrice.ToString("C")</span></td>
                        <td class="text-end align-middle">
                            <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Edit" asp-route-id="@f.Id">Edit</a>
                            <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal" data-id="@f.Id" data-title="@f.FlightNumber">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <div>
            Showing @Model.Flights.Count of @Model.TotalCount
        </div>
        <nav>
            <ul class="pagination mb-0">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link" asp-action="Search" asp-route-DestinationCity="@ViewContext.HttpContext.Request.Query["DestinationCity"]" asp-route-DepartureFromUtc="@ViewContext.HttpContext.Request.Query["DepartureFromUtc"]" asp-route-DepartureToUtc="@ViewContext.HttpContext.Request.Query["DepartureToUtc"]" asp-route-NumberOfPassengers="@ViewContext.HttpContext.Request.Query["NumberOfPassengers"]" asp-route-pageIndex="@(Model.PageIndex - 1)" asp-route-pageSize="@Model.PageSize">Previous</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @Model.PageIndex of @Model.TotalPages</span>
                </li>
                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link" asp-action="Search" asp-route-DestinationCity="@ViewContext.HttpContext.Request.Query["DestinationCity"]" asp-route-DepartureFromUtc="@ViewContext.HttpContext.Request.Query["DepartureFromUtc"]" asp-route-DepartureToUtc="@ViewContext.HttpContext.Request.Query["DepartureToUtc"]" asp-route-NumberOfPassengers="@ViewContext.HttpContext.Request.Query["NumberOfPassengers"]" asp-route-pageIndex="@(Model.PageIndex + 1)" asp-route-pageSize="@Model.PageSize">Next</a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Delete Flight</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete flight <strong id="deleteFlightTitle"></strong>?</p>
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post" asp-action="Delete">
                    <input type="hidden" name="id" id="deleteFlightId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var flightId = button.getAttribute('data-id');
            var flightTitle = button.getAttribute('data-title');
            document.getElementById('deleteFlightId').value = flightId;
            document.getElementById('deleteFlightTitle').textContent = flightTitle;
        });
    </script>
}
