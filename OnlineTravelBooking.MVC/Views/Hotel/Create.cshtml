@using OnlineTravelBooking.Domain.Common.Enums.HotelEnum
@using OnlineTravelBooking.MVC.Models.HotelViewModel
@model HotelListVM

@{
    ViewData["Title"] = "Create Hotel";
}

<div class="row justify-content-center align-content-center mt-3">
    <h1 class="col-8 my-4">Create Hotel</h1>

    <form method="post"
          asp-controller="Hotel"
          asp-action="Create"
          class="row col-8">

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- Hotel Name -->
        <div class="form-group mb-3 col-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <!-- Description -->
        <div class="form-group mb-3 col-6">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control"></textarea>
        </div>

        <!-- Address -->
        <div class="form-group mb-3 col-6">
            <label asp-for="Address" class="form-label"></label>
            <input asp-for="Address" class="form-control" />
        </div>

        <!-- City -->
        <div class="form-group mb-3 col-6">
            <label asp-for="City" class="form-label"></label>
            <input asp-for="City" class="form-control" />
        </div>

        <!-- Country -->
        <div class="form-group mb-3 col-6">
            <label asp-for="Country" class="form-label"></label>
            <input asp-for="Country" class="form-control" />
        </div>

        <!-- Postal Code -->
        <div class="form-group mb-3 col-6">
            <label asp-for="PostalCode" class="form-label"></label>
            <input asp-for="PostalCode" class="form-control" />
        </div>

        <!-- Star Rating -->
        <div class="form-group mb-3 col-6">
            <label asp-for="StarRating" class="form-label"></label>
            <input asp-for="StarRating" type="number" min="1" max="5" class="form-control" />
        </div>

        <div class="form-group">
            <label>Longitude</label>
            <input asp-for="Longitude" class="form-control" />
            <span asp-validation-for="Longitude" class="form-control"></span>
        </div>
        <div class="form-group">
            <label>Latitude</label>
            <input asp-for="Latitude" class="form-control" />
            <span asp-validation-for="Latitude" class="form-control"></span>
        </div>

        <!-- Check In -->
        <div class="form-group mb-3 col-6">
            <label asp-for="CheckInTime" class="form-label"></label>
            <input asp-for="CheckInTime" type="time" class="form-control" />
        </div>

        <!-- Check Out -->
        <div class="form-group mb-3 col-6">
            <label asp-for="CheckOutTime" class="form-label"></label>
            <input asp-for="CheckOutTime" type="time" class="form-control" />
        </div>

        <!-- Contact Phone -->
        <div class="form-group mb-3 col-6">
            <label asp-for="ContactPhone" class="form-label"></label>
            <input asp-for="ContactPhone" class="form-control" />
        </div>

        <!-- Website -->
        <div class="form-group mb-3 col-6">
            <label asp-for="WebsiteURL" class="form-label"></label>
            <input asp-for="WebsiteURL" class="form-control" />
        </div>

        <hr class="mt-4" />

        <!-- ================= ROOMS ================= -->
        <h4 class="mt-4">Rooms</h4>

        @for (int i = 0; i < Model.roomList.Count; i++)
        {
            <div class="border p-3 mb-3">
                <div class="form-group mb-2">
                    <label>Room Number</label>
                    <input asp-for="roomList[i].RoomNum" class="form-control" />
                </div>

                <div class="form-group mb-2">
                    <label>Base Price / Night</label>
                    <input asp-for="roomList[i].BasePricePerNight" class="form-control" />
                </div>
                <div class="form-group mb-2">
                    <label>Currency</label>
                    <select asp-for="roomList[i].Currency" class="form-control">
                        <option value="EGP">EGP</option>
                        <option value="USD">USD</option>
                        <option value="EUR">EUR</option>
                    </select>
                </div>
                <div class="form-group mb-2">
                    <label>Description</label>
                    <textarea asp-for="roomList[i].Description"
                              class="form-control"></textarea>
                </div>

                <div class="form-group form-check mb-2">
                    <input asp-for="roomList[i].Refundable"
                           class="form-check-input"
                           type="checkbox" />

                    <label asp-for="roomList[i].Refundable"
                           class="form-check-label">
                        Refundable
                    </label>
                </div>


                <div class="form-group mb-2">
                    <label>Max People</label>
                    <input asp-for="roomList[i].MaxPeople" class="form-control" />
                </div>

                <div class="form-group mb-2">
                    <label>Status</label>
                    <select asp-for="roomList[i].roomStatus" class="form-control">
                        <option value="DesertView">DesertView</option>
                        <option value="SeaView">SeaView</option>
                    </select>
                </div>

                <div class="form-group mb-2">
                    <label>Type</label>
                    <select asp-for="roomList[i].roomType" class="form-control">
                        <option value="singleRoom">singleRoom</option>
                        <option value="doubleRoom">doubleRoom</option>
                        <option value="TrioleRoom">TrioleRoom</option>
                    </select>
                </div>

                <div class="form-group mb-2">
                    <label>Availability</label>
                    <select asp-for="roomList[i].roomAvailability" class="form-control">
                        <option value="Available">Available</option>
                        <option value="Occupied">Occupied</option>
                    </select>
                </div>
            </div>
        }


        <div class="mt-4 m-auto">
            <input class="btn btn-primary" type="submit" value="Save" />
            <a asp-controller="Hotel"
               asp-action="Index"
               class="btn btn-outline-dark">
                Back to list
            </a>
        </div>
    </form>
</div>
