@using OnlineTravelBooking.MVC.Models;
@model IEnumerable<TourDto>


@{
    ViewData["Title"] = "Tour List";
}


<h1>All Tours</h1>
<br />
<br />
<a class="btn btn-primary" asp-controller="Tour" asp-action="Create">Create Tour</a>
<br />
<div id="EmployeeTableContainer">
    @if (Model.Any())
    {

         <table class="table table-striped table-hover mt-3">
        <thead class="text-center">
            <tr>
                <th>@Html.DisplayNameFor(e => e.Title)</th>
                <th>@Html.DisplayNameFor(e => e.Slug)</th>
                <th>@Html.DisplayNameFor(e => e.Price)</th>
                <th>@Html.DisplayNameFor(e => e.ProviderContact)</th>
                <th>@Html.DisplayNameFor(e=>e.ProviderName)</th>
                <th>@Html.DisplayNameFor(e => e.AverageRating)</th>
                <th>@Html.DisplayNameFor(e => e.duration)</th>
                <th>@Html.DisplayNameFor(e => e.BookingCount)</th>
                    <th>@Html.DisplayNameFor(e => e.Summary)</th>
                    <th>@Html.DisplayNameFor(e => e.Description)</th>
                <th>Details </th>
                <th>Update</th>
                <th>Delete</th>
            </tr>
        </thead>
        <tbody class="text-center">
            @foreach (var tour in Model)
            {
                <tr>

                    <td>@tour.Title</td>
                    <td>@tour.Slug</td>
                    <td>@tour.Price</td>
                    <td>@tour.ProviderContact</td>
                    <td>@tour.ProviderName</td>
                    <td>@tour.AverageRating</td>
                        <td>@tour.duration</td>
                        <td>@tour.BookingCount</td>
                        <td>@tour.Summary</td>
                        <td>@tour.Description</td>


					 @* @Html.Partial("_ButtonsPartialView", tour.Id)  *@
					<partial name="_ButtonsPartialView" model="tour.Id" />

                    <td>
                        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@tour.Id">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                        <!-- Delete Modal -->
                        <div class="modal fade" id="deleteModal-@tour.Id" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h1 class="modal-title fs-5" id="exampleModalLabel">Delete Tour</h1>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        Are You Sure to Delete this Tour?
                                    </div>
                                    <div class="modal-footer">
                                        <form method="post" asp-action="Delete" asp-controller="Tour" asp-route-tourId="@tour.Id" class="mt-4">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                            <input type="submit" value="Delete" class="btn btn-danger" />
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table> 
    }
    else
    {
        <div class="alert alert-info mt-3">
            <h2>No Tours Found !!</h2>
        </div>
    }
</div>
