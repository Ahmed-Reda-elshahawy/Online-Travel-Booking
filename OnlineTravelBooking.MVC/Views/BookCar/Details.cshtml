@* OnlineTravelBooking.MVC/Views/BookCar/Details.cshtml *@
@model OnlineTravelBooking.MVC.Models.CarDto
@{
    ViewData["Title"] = "Car Details";
}

<h1>Car Details</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4>@Model.Brand @Model.Model (@Model.Year)</h4>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="text-center mb-4">
                        <img src="~/Files/Images/@Model.ImageUrl" alt="@Model.Brand @Model.Model"
                             class="img-fluid rounded" style="max-height: 400px;" />
                    </div>
                }

                <dl class="row">
                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Brand)</dt>
                    <dd class="col-sm-8">@Model.Brand</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Model)</dt>
                    <dd class="col-sm-8">@Model.Model</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Type)</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-info">@Model.Type</span>
                    </dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.TransmissionType)</dt>
                    <dd class="col-sm-8">@Model.TransmissionType</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.FuelType)</dt>
                    <dd class="col-sm-8">@Model.FuelType</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.SeatingCapacity)</dt>
                    <dd class="col-sm-8">@Model.SeatingCapacity seats</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.PricePerDay)</dt>
                    <dd class="col-sm-8">
                        <strong class="text-success">@Model.PricePerDay.ToString("C") / day</strong>
                    </dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Year)</dt>
                    <dd class="col-sm-8">@Model.Year</dd>

                    @if (!string.IsNullOrEmpty(Model.LicensePlate))
                    {
                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.LicensePlate)</dt>
                        <dd class="col-sm-8">@Model.LicensePlate</dd>
                    }

                    @if (!string.IsNullOrEmpty(Model.Color))
                    {
                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Color)</dt>
                        <dd class="col-sm-8">@Model.Color</dd>
                    }

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.IsAvailable)</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsAvailable)
                        {
                            <span class="badge bg-success">
                                <i class="fas fa-check"></i> Available
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                <i class="fas fa-times"></i> Not Available
                            </span>
                        }
                    </dd>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Description)</dt>
                        <dd class="col-sm-8">@Model.Description</dd>
                    }

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</dd>

                    @if (Model.UpdatedAt.HasValue)
                    {
                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.UpdatedAt)</dt>
                        <dd class="col-sm-8">@Model.UpdatedAt.Value.ToString("MMM dd, yyyy hh:mm tt")</dd>
                    }
                </dl>
            </div>
            <div class="card-footer">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="fas fa-edit"></i> Edit
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
                <button type="button" class="btn btn-danger float-end" data-bs-toggle="modal" data-bs-target="#deleteModal">
                    <i class="fas fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Delete Car</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this car?</p>
                <p><strong>@Model.Brand @Model.Model (@Model.Year)</strong></p>
            </div>
            <div class="modal-footer">
                <form method="post" asp-action="Delete" asp-controller="BookCar" asp-route-carId="@Model.Id">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}