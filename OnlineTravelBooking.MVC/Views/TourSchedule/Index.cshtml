@using OnlineTravelBooking.Application.Abstractions
@using OnlineTravelBooking.Domain.Entities.Tour
@using OnlineTravelBooking.MVC.Models;
@model IEnumerable<TourScheduleDto>
@inject IGenericRepository<Tour> tourRepository


@{
    ViewData["Title"] = "Tour Schedule List";
}
@{
    var Tours = tourRepository.GetAll().Result;
    var tourNames = Tours.ToDictionary(t => t.Id, t => t.Title);

}


<h1>All Tours</h1>
<br />
<br />
<a class="btn btn-primary" asp-controller="TourSchedule" asp-action="Create">Create Tour</a>
<br />
<div id="EmployeeTableContainer">
    @if (Model.Any())
    {
        
            

        <table class="table table-striped table-hover mt-3">
            <thead class="text-center">
                <tr>
                    <th>TourName</th>
                    <th>@Html.DisplayNameFor(e => e.StartDate)</th>
                    <th>@Html.DisplayNameFor(e => e.EndDate)</th>
                    <th>@Html.DisplayNameFor(e => e.AvailableSeats)</th>
                    @* <th>Details </th> *@
                    <th>Update</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody class="text-center">
                @foreach (var tour in Model)
                {
                    <tr>

                        <td>@tourNames[tour.TourId]</td>
                        <td>@tour.StartDate</td>
                        <td>@tour.EndDate</td>
                        <td>@tour.AvailableSeats</td>


                        @* @Html.Partial("_ButtonsPartialView", tour.Id)  *@
                        @* <partial name="_ButtonsPartialView" model="tour.Id" /> *@
                        <td>
                            <a class="btn btn-success" asp-controller="TourSchedule" asp-action="Edit" asp-route-id="@tour.Id">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                        </td>

                        <td>
                            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@tour.Id">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                            <!-- Delete Modal -->
                            <div class="modal fade" id="deleteModal-@tour.Id" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h1 class="modal-title fs-5" id="exampleModalLabel">Delete Tour</h1>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            Are You Sure to Delete this Tour?
                                        </div>
                                        <div class="modal-footer">
                                            <form method="post" asp-action="Delete" asp-controller="TourSchedule" asp-route-Id="@tour.Id" class="mt-4">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                <input type="submit" value="Delete" class="btn btn-danger" />
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info mt-3">
            <h2>No Tours Found !!</h2>
        </div>
    }
</div>
