@model BookingsViewModel

@{
    ViewData["Title"] = "Admin Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">All Bookings</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Bookings.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-primary text-white">
                        <tr>
                            <th>Booking Ref</th>
                            <th>Customer</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Total Price</th>
                            <th>Payment</th>
                            <th>Booking Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model.Bookings)
                        {
                            <tr>
                                <td class="align-middle fw-semibold">@booking.BookingReference</td>
                                <td class="align-middle">
                                    <div>@booking.UserName</div>
                                    <small class="text-muted">@booking.UserEmail</small>
                                </td>
                                <td class="align-middle">
                                    <span class="badge bg-info">@booking.Category</span>
                                </td>
                                <td class="align-middle">
                                    @{
                                        var statusColor = booking.Status switch
                                        {
                                            "Confirmed" => "bg-success",
                                            "Pending" => "bg-warning",
                                            "Cancelled" => "bg-danger",
                                            "Completed" => "bg-primary",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @statusColor">@booking.Status</span>
                                </td>
                                <td class="align-middle">
                                    @booking.TotalPrice.ToString("C") <span class="text-muted">@booking.Currency</span>
                                </td>
                                <td class="align-middle">
                                    @{
                                        var paymentColor = booking.PaymentStatus switch
                                        {
                                            "Paid" => "bg-success",
                                            "Pending" => "bg-warning",
                                            "Failed" => "bg-danger",
                                            "Refunded" => "bg-info",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @paymentColor">@booking.PaymentStatus</span>
                                </td>
                                <td class="align-middle">
                                    @booking.BookingDate.ToString("dd MMM yyyy HH:mm")
                                </td>
                                <td class="text-end align-middle">
                                    <a class="btn btn-sm btn-outline-secondary me-1" href="@Url.Action("Details", new { id = booking.Id })">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center p-5">
                <p class="text-muted">No bookings found.</p>
            </div>
        }
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <div>
            Showing @Model.Bookings.Count of @Model.TotalCount bookings
        </div>
        <nav>
            <ul class="pagination mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-pageIndex="@(Model.PageIndex - 1)" asp-route-pageSize="@Model.PageSize">Previous</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @Model.PageIndex of @Model.TotalPages</span>
                </li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-pageIndex="@(Model.PageIndex + 1)" asp-route-pageSize="@Model.PageSize">Next</a>
                </li>
            </ul>
        </nav>
    </div>
</div>