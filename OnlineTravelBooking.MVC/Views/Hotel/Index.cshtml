@using OnlineTravelBooking.MVC.Models.HotelViewModel
@model IEnumerable<HotelListVM>

@{
    ViewData["Title"] = "Hotel List";
}

<h1>All Hotels</h1>
<br />

<a class="btn btn-primary" asp-controller="Hotel" asp-action="Create">
    Create Hotel
</a>

@if (Model.Any())
{
    <table class="table table-striped table-hover mt-3">
        <thead class="text-center">
            <tr>
                <th>@Html.DisplayNameFor(h => h.Name)</th>
                <th>@Html.DisplayNameFor(h => h.City)</th>
                <th>@Html.DisplayNameFor(h => h.Country)</th>
                <th>@Html.DisplayNameFor(h => h.StarRating)</th>
                <th>Details</th>
                <th>Update</th>
                <th>Delete</th>
            </tr>
        </thead>

        <tbody class="text-center">
            @foreach (var hotel in Model)
            {
                <tr>
                    <td>@hotel.Name</td>
                    <td>@hotel.City</td>
                    <td>@hotel.Country</td>
                    <td>@hotel.StarRating ⭐</td>

                    <!-- Details -->
                    <td>
                        <a class="btn btn-info btn-sm"
                           asp-controller="Hotel"
                           asp-action="Details"
                           asp-route-id="@hotel.Id">
                            Details
                        </a>
                    </td>

                    <!-- Update -->
                    <td>
                        <a class="btn btn-warning btn-sm"
                           asp-controller="Hotel"
                           asp-action="Edit"
                           asp-route-id="@hotel.Id">
                            Update
                        </a>
                    </td>

                    <!-- Delete -->
                    <td>
                        <button type="button"
                                class="btn btn-danger btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal-@hotel.Id">
                            Delete
                        </button>

                        <!-- Delete Modal -->
                        <div class="modal fade"
                             id="deleteModal-@hotel.Id"
                             tabindex="-1"
                             aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Delete Hotel</h5>
                                        <button type="button"
                                                class="btn-close"
                                                data-bs-dismiss="modal"></button>
                                    </div>

                                    <div class="modal-body">
                                        Are you sure you want to delete <b>@hotel.Name</b>?
                                    </div>

                                    <div class="modal-footer">
                                        <form method="post"
                                              asp-controller="Hotel"
                                              asp-action="Delete"
                                              asp-route-id="@hotel.Id">
                                            <button type="button"
                                                    class="btn btn-secondary"
                                                    data-bs-dismiss="modal">
                                                Cancel
                                            </button>
                                            <button type="submit"
                                                    class="btn btn-danger">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info mt-3">
        <h4>No Hotels Found !!</h4>
    </div>
}
