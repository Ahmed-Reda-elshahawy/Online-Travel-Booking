@model CreateFlightCommandViewModel

@{
    ViewData["Title"] = "Create Flight";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h4 class="card-title mb-3">Create Flight</h4>

                <form asp-action="Create" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger d-none" data-valmsg-summary="true"></div>

                    <div class="row g-3">
                        <div class="col-md-6 form-floating">
                            <input asp-for="FlightNumber" class="form-control" placeholder="FL123" />
                            <label asp-for="FlightNumber">Flight Number</label>
                            <span asp-validation-for="FlightNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 form-floating">
                            <input asp-for="AirlineName" class="form-control" placeholder="Airline" />
                            <label asp-for="AirlineName">Airline</label>
                            <span asp-validation-for="AirlineName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 form-floating">
                            <input asp-for="AircraftType" class="form-control" placeholder="Boeing 737" />
                            <label asp-for="AircraftType">Aircraft Type</label>
                            <span asp-validation-for="AircraftType" class="text-danger small"></span>
                        </div>

                        <div class="col-md-3 form-floating">
                            <input asp-for="OriginAirportCode" class="form-control" placeholder="ABC" />
                            <label asp-for="OriginAirportCode">Origin Code</label>
                            <span asp-validation-for="OriginAirportCode" class="text-danger small"></span>
                        </div>

                        <div class="col-md-3 form-floating">
                            <input asp-for="OriginCity" class="form-control" placeholder="City" />
                            <label asp-for="OriginCity">Origin City</label>
                            <span asp-validation-for="OriginCity" class="text-danger small"></span>
                        </div>

                        <div class="col-md-3 form-floating">
                            <input asp-for="DestinationAirportCode" class="form-control" placeholder="DEF" />
                            <label asp-for="DestinationAirportCode">Destination Code</label>
                            <span asp-validation-for="DestinationAirportCode" class="text-danger small"></span>
                        </div>

                        <div class="col-md-3 form-floating">
                            <input asp-for="DestinationCity" class="form-control" placeholder="City" />
                            <label asp-for="DestinationCity">Destination City</label>
                            <span asp-validation-for="DestinationCity" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 form-floating">
                            <input asp-for="DepartureTimeUtc" type="datetime-local" class="form-control" />
                            <label asp-for="DepartureTimeUtc">Departure (UTC)</label>
                            <span asp-validation-for="DepartureTimeUtc" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 form-floating">
                            <input asp-for="ArrivalTimeUtc" type="datetime-local" class="form-control" />
                            <label asp-for="ArrivalTimeUtc">Arrival (UTC)</label>
                            <span asp-validation-for="ArrivalTimeUtc" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 form-floating">
                            <input asp-for="FirstClassRows" class="form-control" id="FirstClassRows" placeholder="2" />
                            <label asp-for="FirstClassRows">First Class Rows</label>
                            <span asp-validation-for="FirstClassRows" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 form-floating">
                            <input asp-for="BusinessClassRows" class="form-control" id="BusinessClassRows" placeholder="4" />
                            <label asp-for="BusinessClassRows">Business Class Rows</label>
                            <span asp-validation-for="BusinessClassRows" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 form-floating">
                            <input asp-for="EconomyClassRows" class="form-control" id="EconomyClassRows" placeholder="20" />
                            <label asp-for="EconomyClassRows">Economy Class Rows</label>
                            <span asp-validation-for="EconomyClassRows" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Total Seats (calculated)</label>
                            <div class="form-control bg-light" id="calculatedTotal">0</div>
                        </div>

                        <div class="col-md-4 form-floating">
                            <input asp-for="Currency" class="form-control" placeholder="USD" />
                            <label asp-for="Currency">Currency</label>
                            <span asp-validation-for="Currency" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 form-floating">
                            <input asp-for="EconomyPrice" class="form-control" placeholder="99.99" />
                            <label asp-for="EconomyPrice">Economy Price</label>
                            <span asp-validation-for="EconomyPrice" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 form-floating">
                            <input asp-for="BusinessPrice" class="form-control" placeholder="199.99" />
                            <label asp-for="BusinessPrice">Business Price</label>
                            <span asp-validation-for="BusinessPrice" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 form-floating">
                            <input asp-for="FirstClassPrice" class="form-control" placeholder="299.99" />
                            <label asp-for="FirstClassPrice">First Class Price</label>
                            <span asp-validation-for="FirstClassPrice" class="text-danger small"></span>
                        </div>

                        <div class="col-12 text-end mt-2">
                            <a asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
                            <button type="submit" class="btn btn-success">Create Flight</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var vs = document.querySelector('[data-valmsg-summary="true"]');
            if (!vs) return;
            var text = (vs.textContent || vs.innerText || '').trim();
            if (text.length > 0) {
                vs.classList.remove('d-none');
                vs.classList.add('alert', 'alert-danger');
            } else {
                vs.classList.add('d-none');
            }

            // fixed seats per row
            var seatsPerRow = 6;

            function computeTotal() {
                var first = parseInt(document.getElementById('FirstClassRows')?.value || '0');
                var business = parseInt(document.getElementById('BusinessClassRows')?.value || '0');
                var economy = parseInt(document.getElementById('EconomyClassRows')?.value || '0');
                var total = (first + business + economy) * seatsPerRow;
                var totalEl = document.getElementById('calculatedTotal');
                if (totalEl) totalEl.textContent = total;
            }

            ['FirstClassRows','BusinessClassRows','EconomyClassRows'].forEach(function(id){
                var el = document.getElementById(id);
                if(el) el.addEventListener('input', computeTotal);
            });

            computeTotal();
        });
    </script>
}
